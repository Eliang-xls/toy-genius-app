{
  "expo": {
    "name": "Toy Legion",
    "slug": "toy-legion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5D4037"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.toygenius.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5D4037"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.toygenius.app"
    },
    "scheme": "toygenius",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cb7b67de-b06d-4760-80cd-54d3423e9e56"
      }
    },
    "owner": "eliang-expo"
  }
}
